# Webex Calling MCP Server configuration
# Copy this file to .env and fill in your values, OR set these as environment
# variables (e.g. in the `env` block of claude_desktop_config.json).
# Environment variables take precedence over this file.

# --- Required ---
# Your Webex access token (personal token, bot token, or OAuth token).
WEBEX_ACCESS_TOKEN=your_webex_access_token_here

# --- Optional: API endpoints ---
# Base URL for the standard Webex APIs.
WEBEX_BASE_URL=https://webexapis.com/v1
# Base URL for the analytics / detailed call history (CDR) APIs.
WEBEX_ANALYTICS_BASE_URL=https://analytics.webexapis.com/v1

# --- Optional: HTTP behaviour ---
# Per-request timeout in seconds.
WEBEX_REQUEST_TIMEOUT=30
# Number of automatic retries for transient errors (429/5xx/network).
WEBEX_MAX_RETRIES=3
# Base backoff (seconds) for exponential retry delays.
WEBEX_RETRY_BACKOFF=0.5
# Max pooled HTTP connections.
WEBEX_MAX_CONNECTIONS=20

# --- Optional: Logging ---
# One of CRITICAL, ERROR, WARNING, INFO, DEBUG. Logs go to stderr.
WEBEX_LOG_LEVEL=INFO
